<?xml version="1.0"?>
<ruleset name="WP Sync DB">
    <description>WordPress Coding Standards for WP Sync DB</description>

    <!-- Use WordPress-Core ruleset as base -->
    <rule ref="WordPress-Core"/>

    <!-- Text domain configuration for 'wp-sync-db' -->
    <config name="text_domain" value="wp-sync-db"/>

    <!-- Exclude lib/ and template/ directories -->
    <exclude-pattern>*/lib/*</exclude-pattern>
    <exclude-pattern>*/template/*</exclude-pattern>

    <!-- Exclude vendor directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>

    <!-- Show progress -->
    <arg value="p"/>

    <!-- Show sniff codes -->
    <arg value="s"/>

    <!-- Set colors for output -->
    <arg name="colors"/>

    <!-- Check all PHP files -->
    <arg name="extensions" value="php"/>

    <!-- Check files in the project root -->
    <file>.</file>
</ruleset>
